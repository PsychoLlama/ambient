//! The smallest possible Ambient program.
//!
//! `ambient run` compiles the package and calls its `run` function. The
//! entry declares its abilities up front — printing is a side effect, so
//! it needs `Stdio` — and performs them with `!`.

use core::system::Stdio;

pub fn run(): () with Stdio {
  Stdio::out!("Hello, world!");
}
