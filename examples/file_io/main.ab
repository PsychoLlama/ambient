//! File I/O example using the FileSystem ability.
//!
//! Writes a file, reads it back, recovers from a missing-file read with
//! an Exception handler, then cleans up.

/// Entry point demonstrating filesystem operations.
pub fn run(): () with FileSystem, Console {
    let path = "/tmp/ambient_file_io_example.txt";

    // Write a file, then read it back.
    platform.FileSystem.write!(path, "Hello from the FileSystem ability!");
    let content = platform.FileSystem.read!(path);
    platform.Console.println!(content);

    // Reading a missing file raises a catchable exception.
    let fallback = handle {
        platform.FileSystem.read!("/tmp/ambient_file_io_missing.txt")
    } {
        Exception.throw(msg) => "missing file, using a fallback"
    };
    platform.Console.println!(fallback);

    // Clean up.
    platform.FileSystem.remove!(path);
}
