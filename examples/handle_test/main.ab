//! Handle expressions test.
//!
//! Demonstrates handle expressions with ability handlers.

use platform::Stdio;

/// Simple function that returns a value.
fn simple_function(): Number {
  100
}

/// Tests a simple handle with no ability use.
fn test_simple_handle(): Number {
  handle simple_function() {
    Stdio::out(msg) => {
      resume(())
    }
  }
}

/// Tests handle expression with multiple handlers.
fn test_multiple_handlers(): Number {
  handle simple_function() {
    Stdio::out(msg) => {
      resume(())
    },
    Exception::throw(e) => {
      resume(())
    }
  }
}

pub fn run(): Number {
  let r1 = test_simple_handle();
  let r2 = test_multiple_handlers();
  // Both should return 100
  r1 + r2
}
