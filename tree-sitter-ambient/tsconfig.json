{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "allowJs": true,
    "checkJs": true,
    "moduleResolution": "node",
    "types": ["node"]
  },
  "include": ["grammar.js"],
  "exclude": ["node_modules", "src"]
}
